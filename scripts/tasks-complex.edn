{:gen-presets {:kind :complex, :doc "Write a curated preset pack of character/monster EDN files. --out <dir>", :form "(apply load-file [\"scripts/gen_presets.clj\"])"}, :render-test {:kind :complex, :doc "Pixel-verified proof (real headless-Chromium WebGL2 readPixels, not just \"compiles\")\n                  that a composed preset (kami.isekai.render-adapter + kotoba-lang/webgpu's\n                  kami.scene2d/kami.sprite-gpu) actually draws — the first real pixel of a\n                  kami-isekai-assets character/monster on screen. Needs a sibling checkout of\n                  kotoba-lang/webgpu (+ ITS sibling kotoba-lang/expr, for kami.wgsl) next to this\n                  repo — i.e. orgs/kotoba-lang/{kami-isekai-assets,webgpu,expr}, the same layout\n                  the west-managed superproject already checks these out in. Shells `bb` back out\n                  with :dir set to the webgpu sibling because kami.playwright's bridge script and\n                  the sprite-SDF GLSL fixtures are read via cwd-relative paths there (matching every\n                  OTHER playwright_*_test.clj in that repo) — see test/render_pixel_test.clj.", :form "(babashka.process/shell {:dir \"../webgpu\"} \"bb\" \"--classpath\" \"../kami-isekai-assets/src:src:../expr/src\" \"-f\" (str (System/getProperty \"user.dir\") \"/test/render_pixel_test.clj\"))"}, :test {:kind :complex, :doc "Data gate: every race × class × monster × skill composes to valid kami.sprite2d data.", :form "(load-file \"test/chargen_test.cljc\")"}}
