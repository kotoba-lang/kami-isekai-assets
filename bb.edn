;; babashka tasks.
{:paths ["src" "test" "scripts"]
 :tasks {test {:doc  "Data gate: every race × class × monster × skill composes to valid kami.sprite2d data."
               :task (load-file "test/chargen_test.cljc")}
         gen-presets {:doc  "Write a curated preset pack of character/monster EDN files. --out <dir>"
                      :task (apply load-file ["scripts/gen_presets.clj"])}

         render-test
         {:doc  "Pixel-verified proof (real headless-Chromium WebGL2 readPixels, not just \"compiles\")
                  that a composed preset (kami.isekai.render-adapter + kotoba-lang/webgpu's
                  kami.scene2d/kami.sprite-gpu) actually draws — the first real pixel of a
                  kami-isekai-assets character/monster on screen. Needs a sibling checkout of
                  kotoba-lang/webgpu (+ ITS sibling kotoba-lang/expr, for kami.wgsl) next to this
                  repo — i.e. orgs/kotoba-lang/{kami-isekai-assets,webgpu,expr}, the same layout
                  the west-managed superproject already checks these out in. Shells `bb` back out
                  with :dir set to the webgpu sibling because kami.playwright's bridge script and
                  the sprite-SDF GLSL fixtures are read via cwd-relative paths there (matching every
                  OTHER playwright_*_test.clj in that repo) — see test/render_pixel_test.clj."
          :task (babashka.process/shell
                  {:dir "../webgpu"}
                  "bb" "--classpath" "../kami-isekai-assets/src:src:../expr/src"
                  "-f" (str (System/getProperty "user.dir") "/test/render_pixel_test.clj"))}}}
